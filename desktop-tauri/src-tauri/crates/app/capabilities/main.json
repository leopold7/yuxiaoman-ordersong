{
    "$schema": "https://schema.tauri.app/capabilities/2",
    "identifier": "main-capability",
    "description": "Main window capability",
    "windows": ["main"],
    "local": true,
    "remote": {
        "urls": [
            "http://127.0.0.1:17777/*",
            "http://localhost:17777/*",
            "http://127.0.0.1:5173/*",
            "http://localhost:5173/*"
        ]
    },
    "permissions": [
        "core:default",
        "allow-login-windows"
    ]
}
